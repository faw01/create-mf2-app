{
  "name": "create-mf2-app-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "biome check apps/cli/scripts/ packages/",
    "fix": "biome check --write apps/cli/scripts/ packages/",
    "clean": "git clean -xdf node_modules",
    "ci:version": "changeset version && bun update",
    "ci:publish": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3"
  }
}
